# AI provider keys — copy this file to ".env" and fill in your own keys.
# Any subset works; the pipeline tries providers in this order and skips
# rate-limited ones automatically:
# Gemini -> Groq -> OpenRouter -> Cerebras -> Mistral -> GitHub Models

# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_key_here

# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_key_here

# Optional — a GitHub personal access token enables the GitHub Models
# provider (https://github.com/marketplace/models). In GitHub Actions the
# built-in GITHUB_TOKEN is used automatically.
# GITHUB_TOKEN=your_github_pat_here
